# Copy this to secrets.yaml and fill in actual values.
# secrets.yaml should be gitignored and never committed.

# Discord webhook for alerts and daily digest
discord_webhook: https://discord.com/api/webhooks/<webhook_id>/<webhook_token>

# Mosquitto MQTT credentials for Frigate
frigate_mqtt_user: <username>
frigate_mqtt_password: <password>

# Nuki lock MQTT credentials (if using Nuki)
nuki_mqtt_password: <password>
